# MongoDB Connection
# Option 1: Local MongoDB Instance (default)
MONGODB_URI=mongodb://localhost:27017/drruthnjoroge

# Option 2: MongoDB Atlas Free Tier (uncomment to use)
# Get connection string from MongoDB Atlas:
# 1. Go to https://www.mongodb.com/cloud/atlas
# 2. Create free account
# 3. Create new project and cluster (M0 free tier)
# 4. Click "Connect" and copy connection string
# 5. Replace <username> and <password> and <dbname>
# MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/<dbname>?retryWrites=true&w=majority

# Server Configuration
PORT=3000
NODE_ENV=development

# JWT Secret for Admin Authentication
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production_12345

# Admin Credentials (change in production)
ADMIN_EMAIL=admin@drruthnjoroge.com
ADMIN_PASSWORD=admin123
